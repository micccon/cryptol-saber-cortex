module SimpleAlgorithms where
import SaberTypes
import SaberConstants

// ShiftLeftN to shift a polynomial left by n bits (multiply by 2^n)
PolyShiftLeftN:
    {t}
    (Zero t)
    => Poly t -> Integer -> Poly t
PolyShiftLeftN poly shift = poly << shift

property PolyShiftLeftNProperty (poly : Poly Zq) =
    PolyShiftLeftN poly shift == poly << shift
        where
            shift = 2

// ShiftRightN to shift a polynomial right by n bits (divide by 2^n)
PolyShiftRightN:
    {t}
    (Zero t)
    => Poly t -> Integer -> Poly t
PolyShiftRightN poly shift = poly >> shift

property PolyShiftRightNProperty (poly : Poly Zq) =
    PolyShiftRightN poly shift == poly >> shift
        where
            shift = 2

// Byte String to polynomial
BS2Poly:
    {k}
    (fin k)
    => ByteString (k * 256/8) -> Poly [k]
BS2Poly byteString = split`{each=k} (join byteString)

property BS2PolyProperty (byteString : ByteString (4 * 32)) =
    BS2Poly `{4} byteString == split`{each=4} (join byteString)

// Polynomial to Byte String
Poly2BS:
    {k}
    (fin k)
    => Poly [k] -> ByteString (k * 256/8)
Poly2BS polynomial = split`{each=8} (join polynomial)

property Poly2BSProperty (polynomial : Poly [4]) =
    Poly2BS `{4} polynomial == split`{each=8} (join polynomial)


//==========================================================================
/** 
 * If BS2Poly and Poly2BS are implemented correctly, then either function
 * should act as the "inverse" to the other. These properties prove that 
 * formally. 
 *
 * The first proves that BS2Poly "undoes" Poly2BS.
 * The second proves that Poly2BS "undoes" BS2Poly.
 */
property Poly2BS_BS2Poly_RoundTrip_4 (p : Poly [4]) =
    BS2Poly `{4} (Poly2BS `{4} p) == p
property BS2Poly_Poly2BS_RoundTrip_4 (bs : ByteString (4 * 256/8)) =
        Poly2BS `{4} (BS2Poly `{4} bs) == bs
//==========================================================================


// Byte String to vector of polynomials
BS2PolyVec:
    {k}
    (fin k)
    => ByteString (l * k * 256/8) -> PolyVec [k]
BS2PolyVec byteString = [ BS2Poly polyByteString | polyByteString <- (split`{parts=l} byteString) ]

property BS2PolyVecProperty (byteString : ByteString (4 * 256/8 * l)) =
    BS2PolyVec `{4} byteString == [ BS2Poly `{4} polyByteString | polyByteString <- (split`{parts=l} byteString) ]

// Vector of polynomials to Byte String
PolyVec2BS:
    {k}
    (fin k)
    => PolyVec [k] -> ByteString (l * k * 256/8)
PolyVec2BS vector =
    join [ Poly2BS poly | poly <- vector ]

property PolyVec2BSProperty (vector : PolyVec [4]) =
    PolyVec2BS `{4} vector == join [ Poly2BS `{4} poly | poly <- vector ]


//==========================================================================
/** 
 * If BS2PolyVec and PolyVec2BS are implemented correctly, then either function
 * should act as the "inverse" to the other. These properties prove that 
 * formally. 
 *
 * The first proves that BS2PolyVec "undoes" PolyVec2BS.
 * The second proves that PolyVec2BS "undoes" BS2PolyVec.
 */
 property PolyVec2BS_BS2PolyVec_RoundTrip_4 (v : PolyVec [4]) =
    BS2PolyVec `{4} (PolyVec2BS `{4} v) == v
property BS2PolyVec_PolyVec2BS_RoundTrip_4 (bs : ByteString (l * 4 * 256/8)) =
    PolyVec2BS `{4} (BS2PolyVec `{4} bs) == bs
//==========================================================================



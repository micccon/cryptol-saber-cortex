// (Negacyclic) Polynomial multiplication in Rp or Rq, depending on modulus
PolyMul : {t} (fin t) => Poly [t] -> Poly [t] -> Poly [t]
PolyMul a b =
  [ sum [ contrib i c | i <- [0 .. 255] ] | c <- [0 .. 255] ]
  where
    contrib i c =
      if i <= c
      then (a @ i) * (b @ j)
      else negate ((a @ i) * (b @ j))
      where
        j = (c - i) % 256

property PolyMulProperty (a : Poly Zq) (b : Poly Zq) =
    PolyMul a b == [ sum [ contrib i c | i <- [0 .. 255] ] | c <- [0 .. 255] ]
  where
    contrib i c =
      if i <= c
      then (a @ i) * (b @ j)
      else negate ((a @ i) * (b @ j))
      where
        j = (c - i) % 256
